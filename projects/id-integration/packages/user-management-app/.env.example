# Copy to .env.local for development. Never commit real secrets.

# Base URL of the deployed user-management-apis mount (no trailing slash).
# Example: https://api.example.com/prod/manage
USER_MANAGEMENT_API_BASE_URL=

# OAuth 2.0 token endpoint (RFC 6749) — use OIDC `token_endpoint` from discovery.
# Example: https://id.example.com/api/yourServiceId/auth/token
OAUTH_TOKEN_URL=

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Space-separated scopes granted to the M2M client; must match Authlete and
# user-management-apis expectations (e.g. manage:users:read manage:users:write manage:users:delete manage:users:import).
# Staging inspection (`GET /staging/users` via BFF) requires manage:users:read.
OAUTH_SCOPE=

# --- Amplify SSR / Cognito Hosted UI (set in Amplify console or .env.local for prod-like local tests) ---
# Public origin (https://…, no trailing slash). Required for OAuth redirect/cookies when auth runs
# (production, or local without bypass). Same value for both vars is typical.
# - Local `pnpm dev` with auth bypass: omit both (not used).
# - Amplify Hosting: amplify.yml writes defaults into .env.production if unset; use console + these vars
#   when the real URL is not https://{branch}.{app-id}.amplifyapp.com (e.g. custom domain).
# AMPLIFY_APP_ORIGIN=https://branch.appid.amplifyapp.com
# NEXT_PUBLIC_APP_ORIGIN=https://branch.appid.amplifyapp.com

# Cognito: hosted UI domain only, e.g. myapp-auth.auth.ap-northeast-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

# App client callback URLs must include:
#   {origin}/api/auth/sign-in-callback
#   {origin}/api/auth/sign-out-callback

# Local `pnpm dev`: middleware skips Cognito; you can leave Cognito vars empty if you only need the BFF env above.
