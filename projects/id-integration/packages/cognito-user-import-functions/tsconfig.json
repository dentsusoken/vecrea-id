{
  "compilerOptions": {
    /* Node 20 Lambda runtime + esbuild bundle target */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,

    /* Typecheck only — JS emit is esbuild (`pnpm run build:*`) */
    "noEmit": true,
    "isolatedModules": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/__tests__/**",
    "tests",
    "vitest.config.ts"
  ]
}
