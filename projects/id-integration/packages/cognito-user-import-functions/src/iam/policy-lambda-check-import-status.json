{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:__REGION__:__ACCOUNT_ID__:log-group:/aws/lambda/*"
    },
    {
      "Sid": "DynamoDBScanAndUpdateStagingUsers",
      "Effect": "Allow",
      "Action": [
        "dynamodb:Scan",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:aws:dynamodb:__REGION__:__ACCOUNT_ID__:table/__DDB_STAGING_TABLE_NAME__"
    },
    {
      "Sid": "CognitoDescribeUserImportJob",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:DescribeUserImportJob"
      ],
      "Resource": "arn:aws:cognito-idp:__REGION__:__ACCOUNT_ID__:userpool/__COGNITO_USER_POOL_ID__"
    }
  ]
}
