{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CognitoUserImportJobLogging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": [
        "arn:aws:logs:__REGION__:__ACCOUNT_ID__:log-group:/aws/cognito/*",
        "arn:aws:logs:__REGION__:__ACCOUNT_ID__:log-group:/aws/cognito/*:log-stream:*"
      ]
    }
  ]
}
