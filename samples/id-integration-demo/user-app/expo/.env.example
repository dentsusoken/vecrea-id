EXPO_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# --- Cognito Managed login: passkey registration ---
# When truthy (`1`, `true`, `yes`), signed-in users may see "Add a passkey (Cognito)".
EXPO_PUBLIC_SHOW_PASSKEY_REGISTER_LINK=
# Cognito user pool domain or origin (e.g. `myapp.auth.ap-northeast-1.amazoncognito.com`)
EXPO_PUBLIC_COGNITO_DOMAIN=
# Cognito app client id used in the passkey registration URL query.
EXPO_PUBLIC_COGNITO_CLIENT_ID=
# Optional: override redirect after passkey flow.
# For native, this typically should be a deep link like: `id-integration-demo-expo://page`
EXPO_PUBLIC_PASSKEY_REGISTER_REDIRECT_URI=
