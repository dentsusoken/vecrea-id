# Copy to `.env` or `.env.local` for local development.
# See README.md for full descriptions.

# --- Better Auth ---
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# --- Generic OAuth (`custom` provider) ---
CUSTOM_PROVIDER_CLIENT_ID=
# Optional: leave unset for a public OIDC client (see custom-provider.ts).
# CUSTOM_PROVIDER_CLIENT_SECRET=
CUSTOM_PROVIDER_DISCOVERY_URL=

# --- Cognito Hosted UI: passkey registration link on `/page` ---
# When truthy (`1`, `true`, `yes`), signed-in users may see "Add a passkey (Cognito)".
SHOW_PASSKEY_REGISTER_LINK=
# Cognito domain (host only or full https origin), e.g. myapp.auth.ap-northeast-1.amazoncognito.com
COGNITO_DOMAIN=
# App client id used in the passkey registration URL query.
COGNITO_CLIENT_ID=
# Optional: override redirect after passkey flow. Default: `${BETTER_AUTH_URL}/page`
# PASSKEY_REGISTER_REDIRECT_URI=
