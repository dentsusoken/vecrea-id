# Copy to .env.local for development. Never commit real secrets.

# --- Amplify / Cognito (browser + SSR middleware cookie session) ---
# Do not set `AMPLIFY_APP_ORIGIN` for this app unless you use experimental Cognito Managed
# Login with `createAuthRouteHandlers` (and set `AMPLIFY_EXPERIMENTAL_SERVER_AUTH=true`).
# It enables server-only HttpOnly sessions and breaks client `getCurrentUser` (e.g. header
# nav) while duplicating cookies on deployed hosts. Local dev: omit both unless you use hosted UI.
# AMPLIFY_APP_ORIGIN=https://your-app.amplifyapp.com
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# Base URL of the deployed user-management-apis mount (no trailing slash).
# Example: https://api.example.com/prod/manage
USER_MANAGEMENT_API_BASE_URL=

# OAuth 2.0 token endpoint (RFC 6749) — use OIDC `token_endpoint` from discovery.
# Example: https://id.example.com/api/yourServiceId/auth/token
OAUTH_TOKEN_URL=

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Space-separated scopes granted to the M2M client; must match Authlete and
# user-management-apis expectations (e.g. manage:users:read manage:users:write manage:users:delete manage:users:import).
# Staging inspection (`GET /staging/users` via BFF) requires manage:users:read.
OAUTH_SCOPE=
